✅ 3. Parent Component (WeatherDashboard.tsx)
import React, { useState } from "react";
import { Weather } from "../types/Weather";
import { newYorkData, chicagoData, sfData } from "../data/weatherData";
import WeatherForecast from "./WeatherForecast";
import WeekOverview from "./WeekOverview";
import WeatherAlerts from "./WeatherAlerts";

const WeatherDashboard: React.FC = () => {
  const [city, setCity] = useState("New York");

  const getData = (): Weather[] => {
    switch (city) {
      case "Chicago":
        return chicagoData;
      case "San Francisco":
        return sfData;
      default:
        return newYorkData;
    }
  };

  const data = getData();

  return (
    <div>
      <h2>Select a City</h2>
      <button onClick={() => setCity("New York")}>New York</button>
      <button onClick={() => setCity("Chicago")}>Chicago</button>
      <button onClick={() => setCity("San Francisco")}>San Francisco</button>

      <h1>{city} 7-Day Weather Forecast</h1>

      <WeekOverview data={data} />
      <WeatherForecast data={data} />
      <WeatherAlerts data={data} />
    </div>
  );
};

export default WeatherDashboard;


