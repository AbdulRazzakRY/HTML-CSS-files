import React from "react";
import { Weather } from "../types/Weather";

interface Props {
  data: Weather[];
}

const WeatherForecast: React.FC<Props> = ({ data }) => {
  return (
    <div>
      <h2>Daily Forecast</h2>
      {data.map((day) => (
        <div key={day.id}>
          <h3>{day.day}</h3>
          <p>{day.temperature}°F</p>
          <p>{day.condition}</p>
          <p>Humidity: {day.humidity}%</p>
          <p>Wind: {day.windSpeed} mph</p>

          {day.condition === "Sunny" && <p>Great day for outdoor activities!</p>}
          {day.condition === "Rainy" && <p>Don't forget your umbrella!</p>}
          {day.windSpeed >= 15 && <p>High winds expected</p>}
        </div>
      ))}
    </div>
  );
};

export default WeatherForecast;


✅ 5. Week Overview (WeekOverview.tsx)
import React from "react";
import { Weather } from "../types/Weather";

const WeekOverview: React.FC<{ data: Weather[] }> = ({ data }) => {
  const avgTemp =
    data.reduce((sum, d) => sum + d.temperature, 0) / data.length;

  const hottest = data.reduce((a, b) =>
    a.temperature > b.temperature ? a : b
  );

  const coldest = data.reduce((a, b) =>
    a.temperature < b.temperature ? a : b
  );

  const sunnyDays = data.filter(d => d.condition === "Sunny").length;
  const rainyDays = data.filter(d => d.condition === "Rainy" || d.condition === "Thunderstorm").length;

  return (
    <div>
      <h2>Week Overview</h2>
      <p>Average Temperature: {avgTemp.toFixed(1)}°F</p>
      <p>Hottest Day: {hottest.day} ({hottest.temperature}°F)</p>
      <p>Coldest Day: {coldest.day} ({coldest.temperature}°F)</p>
      <p>Sunny Days: {sunnyDays}</p>
      <p>Rainy Days: {rainyDays}</p>
    </div>
  );
};

export default WeekOverview;


✅ 6. Weather Alerts (WeatherAlerts.tsx)
import React from "react";
import { Weather } from "../types/Weather";

const WeatherAlerts: React.FC<{ data: Weather[] }> = ({ data }) => {
  const rainDays = data.filter(d => d.precipitation > 60);
  const windDays = data.filter(d => d.windSpeed >= 15);

  return (
    <div>
      <h2>Weather Alerts</h2>

      {rainDays.length > 0 && (
        <div>
          <h3>Rain Alert</h3>
          <p>
            Heavy rain expected on:{" "}
            {rainDays.map(d => d.day).join(", ")}
          </p>
        </div>
      )}

      {windDays.length > 0 && (
        <div>
          <h3>Wind Advisory</h3>
          <p>
            Strong winds expected on:{" "}
            {windDays.map(d => d.day).join(", ")}
          </p>
        </div>
      )}
    </div>
  );
};

export default WeatherAlerts;


